# NeuralChat — Environment Variables
# ─────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your API key(s) below
# 3. NEVER commit .env to version control

# ── Server ──────────────────────────────────────────
PORT=5000
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database ─────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/
# MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

DB_NAME=neuralchat

# ── AI Provider ──────────────────────────────────────
# Choose: 'openai' or 'gemini'
AI_PROVIDER=gemini

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
# Other models: gpt-4, gpt-4-turbo, gpt-4o

# Google Gemini (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# ── Limits ───────────────────────────────────────────
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_CONTEXT=20
MAX_HISTORY_STORED=100

# ── Custom System Prompt (optional override) ─────────
# SYSTEM_PROMPT=You are a helpful assistant...
